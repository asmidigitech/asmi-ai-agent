<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_asmi_ai_queue_processor" model="ir.cron">
            <field name="name">Asmi AI Queue Processor</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model.cron_process_ai_queue()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <record id="ir_cron_asmi_ai_stale_recovery" model="ir.cron">
            <field name="name">Asmi AI Stale Recovery</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model.cron_recover_stale_ai_calls()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        
    <record id="ir_cron_crm_leads_to_make_sync" model="ir.cron">
            <field name="name">CRM Leads to Make Sync</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_leads_to_make()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>


        
    </data>
</odoo>
