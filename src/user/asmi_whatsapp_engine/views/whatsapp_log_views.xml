<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asmi_whatsapp_log_tree" model="ir.ui.view">
        <field name="name">asmi.whatsapp.log.tree</field>
        <field name="model">asmi.whatsapp.log</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="create_date"/>
                <field name="lead_id"/>
                <field name="template_code"/>
                <field name="response_status"/>
                <field name="state"/>
                <field name="error_message"/>
            </tree>
        </field>
    </record>

    <record id="view_asmi_whatsapp_log_form" model="ir.ui.view">
        <field name="name">asmi.whatsapp.log.form</field>
        <field name="model">asmi.whatsapp.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="lead_id"/>
                        <field name="template_id"/>
                        <field name="template_code"/>
                        <field name="response_status"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="error_message"/>
                    </group>
                    <notebook>
                        <page string="Request">
                            <field name="request_payload" nolabel="1"/>
                        </page>
                        <page string="Response">
                            <field name="response_body" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asmi_whatsapp_logs" model="ir.actions.act_window">
        <field name="name">WhatsApp Logs</field>
        <field name="res_model">asmi.whatsapp.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_asmi_whatsapp_logs" name="Logs"
              parent="menu_asmi_whatsapp_root"
              action="action_asmi_whatsapp_logs" sequence="20"/>
</odoo>
